# Copy file ini ke `.env` lalu isi dengan nilai dari Fabric Eventstream
# (Custom App > tab "Keys"). File `.env` sudah masuk .gitignore.
#
# EntityPath di akhir connection string sudah berisi event hub name,
# jadi variabel *_EVENTHUB di bawah opsional (auto-derived bila kosong).

HAULING_CONN_STR=Endpoint=sb://<namespace>.servicebus.windows.net/;SharedAccessKeyName=<keyname>;SharedAccessKey=<key>;EntityPath=<eventhub>
STOCKPILE_CONN_STR=Endpoint=sb://<namespace>.servicebus.windows.net/;SharedAccessKeyName=<keyname>;SharedAccessKey=<key>;EntityPath=<eventhub>
BARGE_CONN_STR=Endpoint=sb://<namespace>.servicebus.windows.net/;SharedAccessKeyName=<keyname>;SharedAccessKey=<key>;EntityPath=<eventhub>

# Optional override (default = parsed dari EntityPath di connection string)
# HAULING_EVENTHUB=
# STOCKPILE_EVENTHUB=
# BARGE_EVENTHUB=
